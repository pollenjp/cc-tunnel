@startuml docker_gce_component
' 【役割】論理コンポーネント図
'   cc-tunnel 内部コンポーネント（API Handler, ExecutionProvider, DockerGCEProvider,
'   IdleChecker, VMScaler）の責務と相互依存関係を示す。
'   物理デプロイ配置（VM × N コンテナ）は docker_gce_multi_container.puml を参照。
' Level 3: Component (Docker on GCE — cc-tunnel 内部コンポーネント)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Docker on GCE — cc-tunnel Component Diagram

System_Ext(cc_remote_agent, "cc-remote-agent (GCE VM上)", "GCE VM の startup script で起動。\nClaude CLI を HTTP API でラップ。\nPort: 9091")
System_Ext(compute_api, "Compute Engine API", "Google Cloud\nVM ライフサイクル管理 (create/delete)")
ContainerDb_Ext(db, "PostgreSQL", "PostgreSQL 18-alpine", "session_endpoints: 会話ID↔エンドポイント\nvm_instances: GCE VM 管理")

Container_Boundary(api_boundary, "cc-tunnel API (Go, Cloud Run)") {
  Component(handler, "API Handler", "net/http\n(api/handler.go)", "HTTPリクエスト処理。\n会話CRUD・メッセージ送信。\n202 Accepted後にgoroutineで非同期実行。\nexecutionProvider.Execute() 経由で\nDockerGCEProvider を呼び出す。")

  Component(exec_provider, "ExecutionProvider", "interface\n(provider/provider.go)", "claude CLI 実行バックエンド抽象。\nExecute(ctx, req, onEvent) を定義。\nnewProviderFromEnv(EXECUTION_PROVIDER) で実装を選択。")

  Component(dgce_provider, "DockerGCEProvider", "Go\n(provider/dockergce/provider.go)", "ExecutionProvider 実装。\n\ngetOrCreateEndpoint(conversationID):\n  DB: GetSessionEndpointByConversationID\n  → なければ GetAvailableVMInstance\n    → なければ createGCEVM + waitForVMReady\n  → CreateSessionEndpoint (DB)\n  → IncrementVMActiveContainers (DB)\n\nwaitForVMReady:\n  Stage1: GCE RUNNING + internalIP (3分タイムアウト)\n  Stage2: HTTP /auth/status 応答 (1分タイムアウト)\n\nCleanupOrphans:\n  アイドルセッション削除 + アイドルVM削除")

  Component(idle_checker, "IdleChecker", "Go goroutine\n(provider/dockergce/idle_checker.go)", "設定した間隔 (推奨: 60秒) で\nCleanupOrphans() を定期実行。\nアイドルセッションエンドポイントと\nアイドル GCE VM を削除。")

  Component(vmscaler, "VMScaler", "Go goroutine\n(provider/dockergce/vmscaler.go)", "設定した間隔で\nCleanupOrphans() を定期実行。\nIdleChecker と同じ CleanupOrphans() を使用。\nGCE VM のスケールダウン専用 goroutine として定義。")
}

Rel(handler, exec_provider, "Execute(ctx, req, onEvent)")
Rel(exec_provider, dgce_provider, "DockerGCEProvider が実装")
Rel(dgce_provider, cc_remote_agent, "Claude CLI実行\nremoteclient.NewClient(vmIP:9091).Execute()", "HTTP")
Rel(dgce_provider, compute_api, "instances.insert / instances.delete", "HTTPS (REST)")
Rel(dgce_provider, db, "session_endpoints / vm_instances CRUD", "PostgreSQL (pgx/v5)")
Rel(idle_checker, dgce_provider, "CleanupOrphans() を定期呼び出し")
Rel(vmscaler, dgce_provider, "CleanupOrphans() を定期呼び出し")

note as change_note #FFD700
  変更 (95a54d5): ファイル先頭に役割説明コメントを追加
  （PlantUML 描画には影響なし）
end note

legend right
  **凡例 (基準コミット: 95a54d5)**
  |<#FFD700>  | 変更された要素 |
  |<#90EE90>  | 新規追加の要素 |
endlegend

@enduml
