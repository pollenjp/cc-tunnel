@startuml docker_gce_component
' Level 3: Component (Docker on GCE — cc-tunnel 内部コンポーネント)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Docker on GCE — cc-tunnel Component Diagram\n現在: MockProvider スタブ実装 / 将来: SessionManager + Provisioner + IdleChecker + VMScaler

System_Ext(docker_api, "Docker API (SSH経由) 【将来】", "GCE VM 上の Docker Daemon\nコンテナ管理 (run/stop/rm)")
System_Ext(compute_api, "Compute Engine API 【将来】", "Google Cloud\nVM ライフサイクル管理 (create/delete)")
ContainerDb_Ext(db, "PostgreSQL 【将来】", "PostgreSQL", "session_endpoints・vm_instances テーブル\n（将来実装時に追加予定）")

Container_Boundary(api_boundary, "cc-tunnel API (Go, Cloud Run)") {
  Component(handler, "API Handler", "net/http\n(api/handler.go)", "HTTPリクエスト処理。\n会話CRUD・メッセージ送信。\n202 Accepted後にgoroutineで非同期実行。\nexecutionProvider.Execute() 経由で\nDockerGCEProvider を呼び出す。")

  Component(exec_provider, "ExecutionProvider", "interface\n(provider/provider.go)", "claude CLI 実行バックエンド抽象。\nExecute(ctx, req, onEvent) を定義。\nlocal.LocalDockerProvider と\ndockergce.MockProvider が実装。")

  Component(mock_provider, "DockerGCEProvider (MockProvider)", "Go stub\n(provider/dockergce/mock.go)", "【現在実装】ExecutionProvider を実装するスタブ。\nGCE/Docker 操作なし。uuid 付き固定レスポンスを返す。\n\n【将来実装予定コンポーネント】\n・SessionManager: 会話→エンドポイントマッピング\n  GetOrCreate(conversationID) でコンテナ確保\n・Provisioner: GCE VM + Docker コンテナ操作 (SSH)\n  VM create/delete、docker run/stop/rm\n・IdleChecker: 60秒間隔でコンテナ idle 検出\n  last_activity 15分超 → docker stop + rm\n・VMScaler: 5分間隔で空き VM 削除\n  active_containers = 0 かつ idle_since 5分超 → VM delete")
}

Rel(handler, exec_provider, "Execute(ctx, req, onEvent)")
Rel(exec_provider, mock_provider, "MockProvider が実装")
Rel(mock_provider, docker_api, "【将来】docker run/stop/rm\nコンテナ状態確認", "SSH トンネル")
Rel(mock_provider, compute_api, "【将来】instances.insert / instances.delete", "HTTPS (REST)")
Rel(mock_provider, db, "【将来】session_endpoints / vm_instances CRUD", "PostgreSQL (pgx/v5)")

@enduml
