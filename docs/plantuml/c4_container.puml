@startuml c4_container
' Level 2: Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title cc-tunnel Container Diagram

Person(user, "User", "ブラウザユーザー")
System_Ext(anthropic, "Anthropic API", "Claude AI (claude-sonnet等)")
System_Ext(docker_daemon, "Docker Daemon", "ホストの Docker デーモン。\ncc-tunnel が docker.sock 経由で操作 (DooD)。")

System_Boundary(cctunnel_system, "cc-tunnel") {
  Container(frontend, "Frontend", "React/Vite + nginx", "会話UIを提供。\nnginxがAPIリクエスト(/api/*)を\ncc-tunnel APIにリバースプロキシ。\nPort: 3000\n[compose profile: full]")

  Container(api, "cc-tunnel API", "Go (net/http)", "会話・メッセージ管理REST API。\n202 Accepted後にgoroutineで\nClaude CLI実行・DB保存を行う。\nDooD: docker.sock マウント済み。\nPort: 8080\n[compose デフォルトサービス]")

  Container(session_agent, "cc-remote-agent-{conversationID}", "Go (cc-remote-agent)", "セッションごとの動的コンテナ。\nSessionManager.GetOrCreate で生成・破棄。\n各会話の Claude CLI 実行を担当。\nアイドル15分で自動停止。\nPort: ContainerPort (default: 9091)")

  ContainerDb(db, "PostgreSQL", "PostgreSQL 18-alpine", "会話(conversations)・\nメッセージ(messages)を永続化。\nPort: 5432")
}

Rel(user, frontend, "Webブラウザでアクセス", "HTTP")
Rel(frontend, api, "REST API呼び出し (/api/*)", "HTTP/JSON")
Rel(api, db, "会話・メッセージの読み書き", "PostgreSQL (pgx/v5)")
Rel(api, docker_daemon, "セッションコンテナ管理 (DooD)", "docker.sock")
Rel(docker_daemon, session_agent, "コンテナ起動・停止・削除")
Rel(api, session_agent, "Claude CLI実行 (Execute API)", "HTTP/NDJSON\n(DNS: containerName:port)")
Rel(session_agent, anthropic, "LLM呼び出し (Claude CLI)", "HTTPS")

@enduml
