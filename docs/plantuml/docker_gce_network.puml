@startuml docker_gce_network
' 【役割】GCE VM 周辺のネットワーク構成図
'   docker_gce_architecture.puml がアプリ層 (Container) の関係を、
'   docker_gce_multi_container.puml が pool 管理シーケンスを示すのに対し、
'   本図は VPC / subnet / firewall / external IP / metadata server など
'   「GCE VM の egress と ingress がどう通っているか」を示す。
'
' 関連 ADR:
'   - 2026-05-06_container_manager_on_vm.md (container-manager 導入)
'   - 2026-05-09_gce_vm_egress_via_external_ip.md (ephemeral external IP 採用)
'   - 2026-05-10_iap_oauth_admin_api_shutdown.md (LB 前段 IAP + IAP P4SA)
'
' 関連 PR / Issue:
'   - #60 switch from default VPC to a custom VPC (google_compute_network.cc_tunnel)
'   - #58 attach a dedicated SA to cc-tunnel-managed VMs (vm_runtime_sa)
'   - #57 fix-remote-agent-container-GJjvW (ephemeral external IP)
'   - #62 (issue) defense-in-depth: drop allUsers Cloud Run invoker after IAP rollout

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

' C4 Deployment skin defaults to white legend text on a transparent
' background, which becomes invisible against the white canvas. Force
' a cream background + black text so the legend stays readable.
skinparam legendBackgroundColor #FFFFCC
skinparam legendBorderColor #181818
skinparam legendFontColor #000000

title Docker on GCE — Network Architecture (egress / ingress paths)

' --------------------------------------------------------------------------
' Public internet / external endpoints
' --------------------------------------------------------------------------
Deployment_Node(internet, "Public Internet", "0.0.0.0/0") {
  Container_Ext(browser, "End-user browser", "https://cctunnel.pollenjp.com", "ユーザ ingress エントリ\n(Phase 3: IAP で Google ログイン強制)")
  Deployment_Node(google_apis, "Google APIs (public)", "*.googleapis.com / *.pkg.dev") {
    Container_Ext(ar, "Artifact Registry", "us-central1-docker.pkg.dev", "cc-remote-agent / container-manager image\n(VM SA: roles/artifactregistry.reader)")
    Container_Ext(metadata_pub, "OAuth / IAM endpoints", "oauth2.googleapis.com 等", "Google OAuth (IAP のユーザ認証)\nConsole 作成済み OAuth client が consent を返す")
  }
  Container_Ext(anthropic, "Anthropic API", "api.anthropic.com", "Claude LLM 呼び出し\n(cc-remote-agent から HTTPS)")
  Container_Ext(github_etc, "GitHub / npm / pypi / apt 等", "任意の外部ホスト", "cc-remote-agent コンテナ実行時の依存解決\n(git clone / pip install など)")
}

' --------------------------------------------------------------------------
' GCP Project
' --------------------------------------------------------------------------
Deployment_Node(gcp_project, "GCP Project (cc-tunnel-local)", "Google Cloud") {

  ' ----- External Global HTTPS LB + IAP -----
  Deployment_Node(lb, "External Global HTTPS LB", "google_compute_global_forwarding_rule\nDNS: cctunnel.pollenjp.com (Cloudflare DNS-only)") {
    Container(target_proxy, "target HTTPS proxy + URL map", "/api/* → cct-backend\n/* → fe-backend", "managed SSL cert")
    Container(be_cct, "backend_service: cct-backend", "serverless NEG → cc-tunnel\niap { enabled = var.iap_enabled }", "IAP enable 時:\n- iap_oauth_client_id/secret (Console 作成)\n- roles/iap.httpsResourceAccessor で\n  iap_allowed_members を許可")
    Container(be_fe, "backend_service: fe-backend", "serverless NEG → frontend\niap { enabled = var.iap_enabled }", "同上")
  }

  ' ----- IAP service agent (P4SA) -----
  Deployment_Node(iap_p4sa, "IAP service agent", "google_project_service_identity\nservice-<PROJECT_NUMBER>@gcp-sa-iap.iam.gserviceaccount.com") {
    Container(iap_sa, "IAP P4SA", "Google managed", "LB → Cloud Run の invoke 時の identity\nroles/run.invoker を付与済み")
  }

  ' ----- Cloud Run boundary -----
  Deployment_Node(cloud_run, "Cloud Run service: cc-tunnel", "ingress = INTERNAL_LOAD_BALANCER\nDirect VPC Egress 有効\nrun_sa: cc-runtime-sa (iam.serviceAccountUser on vm_runtime_sa)\ninvoker: IAP P4SA のみ (allUsers は撤去済み, #63)") {
    Container(cctunnel, "cc-tunnel", "Go (Cloud Run)", "DockerGCEProvider 経由で VM lifecycle / cc-remote-agent 呼び出し\nGCE_VM_SUBNETWORK = projects/.../subnetworks/cc-remote-agent-vm\nGCE_VM_SERVICE_ACCOUNT = vm_runtime_sa")
  }

  Deployment_Node(cloud_run_fe, "Cloud Run service: frontend", "ingress = INTERNAL_LOAD_BALANCER\nnginx (envsubst) で /api/* → cc-tunnel.uri") {
    Container(fe, "frontend (SPA + nginx)", "Static + reverse proxy", "BACKEND_URL=/api\nAPI_UPSTREAM=<cc-tunnel.uri>")
  }

  ' ----- Custom VPC -----
  Deployment_Node(vpc, "VPC: cc-tunnel (custom mode)", "google_compute_network.cc_tunnel\nauto_create_subnetworks = false") {

    Deployment_Node(subnet_egress, "subnet: cc-tunnel-egress", "10.8.0.0/26 (us-central1)\nDirect VPC Egress 専用") {
      Container(egress_nic, "Cloud Run egress NIC", "Direct VPC Egress", "cc-tunnel → VM internal IP の発信元\nvar.vpc_connector_subnet_cidr")
    }

    Deployment_Node(subnet_vm, "subnet: cc-remote-agent-vm", "10.16.0.0/20 (us-central1)\nvar.cc_remote_agent_subnet_cidr") {

      Deployment_Node(gce_vm, "GCE VM (cc-tunnel-<uuid>)", "Compute Engine\nlabels: managed-by=cc-tunnel\ntags: [cc-tunnel-agent]\nSA: vm_runtime_sa") {

        Container(nic, "NIC nic0", "AccessConfigs: ONE_TO_ONE_NAT\n→ ephemeral external IP", "**外部 IP 自動付与** (本 PR で追加)\n内部 IP: subnet 10.16.0.0/20 内\n外部 IP: 起動毎に変動")

        Container(metadata_int, "Metadata server", "169.254.169.254", "VM SA token を bridge ネット\nワーク内のコンテナにも提供")

        Deployment_Node(docker, "Docker daemon", "Unix socket: /var/run/docker.sock\n(TCP 2375 は廃止済み — ADR 2026-05-06)") {
          Container(cm, "container-manager", "Go / 9090/tcp", "X-Registry-Auth に metadata 経由の\nSA token を載せて AR pull\ncc-tunnel から HTTP API で操作")
          Container(agent_n, "cc-remote-agent (× N)", "Go / 9091..909N/tcp", "1 VM 内で複数 conversation を多重化\ncc-tunnel ↔ HTTP / Anthropic API ↔ HTTPS")
        }
      }
    }
  }

  ' ----- Firewall rules (network 全体に適用) -----
  Deployment_Node(fw, "VPC firewall rules (cc-tunnel network)", "google_compute_firewall") {
    Container(fw_cm, "cc-tunnel-container-manager (allow)", "ingress / TCP 9090", "source_ranges = vpc_connector_subnet_cidr\ntarget_tags = [cc-tunnel-agent]")
    Container(fw_implicit_deny, "implicit deny-all ingress", "ingress / *", "カスタム VPC では default-allow-* が\n自動作成されないため、明示許可した\nrule のみが ingress を通す")
  }
}

' --------------------------------------------------------------------------
' Egress / ingress relations
' --------------------------------------------------------------------------

' Browser ingress → IAP-fronted LB → Cloud Run
Rel(browser, target_proxy, "HTTPS\ncctunnel.pollenjp.com", "TCP 443")
Rel(target_proxy, be_cct, "/api/* (path matcher)", "")
Rel(target_proxy, be_fe, "/ (default service)", "")
Rel(be_cct, metadata_pub, "IAP enable 時: ユーザを Google OAuth に redirect\n(Console 作成済み OAuth client で consent)", "HTTPS")
Rel(be_cct, cctunnel, "X-Serverless-Authorization 付きで invoke\n(IAP P4SA 経由)", "HTTPS internal")
Rel(be_fe, fe, "同上", "HTTPS internal")
Rel(iap_sa, cctunnel, "roles/run.invoker", "IAM")
Rel(iap_sa, fe, "roles/run.invoker", "IAM")

' Cloud Run → VM internal IP (Direct VPC Egress)
Rel(cctunnel, egress_nic, "Direct VPC Egress 経由で送信", "")
Rel(egress_nic, cm, "container-manager API\n(http://<vm_internal_ip>:9090)", "TCP 内部")
Rel(egress_nic, agent_n, "cc-remote-agent 呼び出し\n(http://<vm_internal_ip>:9091..)", "TCP 内部")
Rel(fw_cm, cm, "ingress を許可", "")

' VM external egress
Rel(nic, ar, "container-manager の image pull\n(SA token を X-Registry-Auth に載せる)", "HTTPS / external IP")
Rel(nic, anthropic, "cc-remote-agent → LLM 呼び出し", "HTTPS / external IP")
Rel(nic, github_etc, "実行時依存解決 (git/npm/pip/apt …)", "HTTPS / external IP")

' Metadata server (SA token)
Rel(cm, metadata_int, "GET /computeMetadata/v1/...\n(SA access token 取得)", "HTTP")

' Public ingress: カスタム VPC では明示 allow rule のみ。
' 外部 IP があっても 22/3389/ICMP は default-allow-* が無いので閉じている。
Rel(internet, fw_implicit_deny, "明示許可されないポートは到達不可", "TCP/UDP/ICMP")

' --------------------------------------------------------------------------
' Notes
' --------------------------------------------------------------------------
note as note_external_ip #FFD700
  **本 PR (#57) の変更点**
  - VM の NetworkInterface に AccessConfigs (ONE_TO_ONE_NAT) を付与
    → ephemeral external IP が VM 起動時に自動付与される
  - 新規 subnet `cc-remote-agent-vm` を追加
  - GCE_VM_SUBNETWORK env を Cloud Run に渡し、CreateInstance 時に subnet を指定
end note

note as note_iap #C8E6C9
  **Phase 3: IAP (ADR 2026-05-10)**
  - LB の両 backend service に `iap { enabled = true, oauth2_client_id, oauth2_client_secret }` を付与
  - OAuth brand と OAuth client は Console 手動作成
    (google_iap_brand / google_iap_client は API shutdown 済み)
  - IAP P4SA (service-<PROJECT_NUMBER>@gcp-sa-iap...) を
    `google_project_service_identity` でプロビジョニングし、
    両 Cloud Run service に roles/run.invoker を付与
  - 認可は backend service スコープの
    roles/iap.httpsResourceAccessor (var.iap_allowed_members)
  - allUsers invoker は撤去済み (#63, Issue #62 クローズ)。
    invoker は IAP P4SA のみ + ingress=INTERNAL_LOAD_BALANCER で
    defense-in-depth
end note

note as note_nat_rejected #FFB6C1
  **Cloud NAT / PGA を採用しなかった理由**
  - VM は AccessConfigs で ephemeral external IP を持つので、
    Artifact Registry も外部依存解決もすべて public 経路で済む
  - NAT Gateway の固定費 + データ処理料金は PoC 段階の VM 数では割に合わない
  - PGA (private_ip_google_access) は外部 IP がある現構成では
    実質的に効かないため、subnet 設定からは取り除いた
  - 将来 external IP を外す方針に転ずる場合は、subnet に PGA を再付与するか
    Cloud NAT を被せる構成へ切り替えれば良い
end note

note as note_hardening #90EE90
  **解消: default-allow-ssh の世界公開**
  カスタム VPC (`google_compute_network.cc_tunnel`,
  auto_create_subnetworks = false) に切り替えたため、
  GCP が default network に自動作成する
  `default-allow-ssh` / `-icmp` / `-rdp` は存在しない。
  外部 IP 付き VM でも、明示的に許可された
  `cc-tunnel-container-manager` (TCP 9090, source =
  vpc_connector_subnet_cidr) 以外の ingress は閉じている。
end note

legend right
  **凡例**
  |<#FFD700>      | 本 PR で変更された要素 |
  |<#C8E6C9>      | Phase 3 IAP 関連 (ADR 2026-05-10) |
  |<#FFB6C1>      | 採用しなかった代替案 |
  |<#90EE90>      | 解消済みの過去課題 |
endlegend

@enduml
